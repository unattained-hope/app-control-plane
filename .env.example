# Apoaap Control Plane — environment template.
# Real values are injected at runtime from the secrets manager (see app/lib/secrets.ts).
# NEVER commit live secret values. process.env is read ONLY by app/lib/config.ts.

# Control plane's OWN Postgres (the control plane owns its own DB).
CONTROL_PLANE_DATABASE_URL="postgresql://cp:cp@localhost:5544/control_plane?schema=public"

# SaleSwitch read-replica DSN — local dev points at the sibling Badgy Postgres
# (docker compose in badgy/ on host port 5433). Production uses a read-only role.
SALESWITCH_REPLICA_URL="postgresql://shopifyadmin:badgy_local@localhost:5433/shopify_apps?schema=public"

# Redis — backs BullMQ (KPI rollups) AND the Socket.IO adapter.
REDIS_URL="redis://localhost:6379"

# WorkOS AuthKit (Google/Microsoft social login).
WORKOS_API_KEY="sk_test_xxx"
WORKOS_CLIENT_ID="client_xxx"
WORKOS_REDIRECT_URI="http://localhost:3000/auth/callback"
WORKOS_COOKIE_PASSWORD="at-least-32-characters-long-secret-value-here"

# Shopify Admin API creds/scopes for reading activeSubscriptions per shop.
# SHOPIFY_API_SECRET must match Badgy's SHOPIFY_API_SECRET so support-chat tokens verify.
SHOPIFY_API_KEY="xxx"
SHOPIFY_API_SECRET="xxx"

# Observability.
SENTRY_DSN=""

# Optional: narrow SaleSwitch admin API base URL for app-backed actions (D2).
# When empty, app-backed actions are hidden and only notes/tags are offered.
SALESWITCH_ADMIN_API_URL=""
SALESWITCH_ADMIN_API_TOKEN=""

# Usage-event ingestion (usage-analytics Phase 2b). Base URL of Badgy's internal
# API and the HMAC secret (MUST equal Badgy's BADGY_INTERNAL_API_SECRET). Empty
# URL or secret => ingestion is disabled (fail-closed, no outbound calls).
SALESWITCH_INTERNAL_API_URL=""
SALESWITCH_INTERNAL_API_SECRET=""
# USAGE_INGEST_CRON="*/1 * * * *"
# USAGE_INGEST_PAGE_SIZE="200"
# USAGE_INGEST_MAX_PAGES_PER_RUN="50"
# USAGE_MIRROR_RETENTION_MONTHS="18"
# USAGE_INGEST_LAG_ALERT_MINUTES="15"

# Usage alerts + weekly digest (usage-analytics Phase 5). Alert rules are seeded
# DISABLED; enable them from the ADMIN UI once thresholds have real data behind them.
# Defaults are the seeded rule thresholds (points/fractions), the digest schedule +
# recipients, the alert-eval safety-net cron, and the per-admin saved-view cap.
# USAGE_ALERT_FUNNEL_DROP_POINTS="0.1"
# USAGE_ALERT_DORMANT_RISE_PERCENT="0.25"
# USAGE_ALERT_WAU_DROP_PERCENT="0.2"
# USAGE_DIGEST_CRON="0 13 * * 1"
USAGE_DIGEST_RECIPIENTS=""
# USAGE_ALERT_EVAL_CRON="45 0 * * *"
# USAGE_SAVED_VIEW_MAX_PER_USER="50"

# Feature-flag read token (cp-feature-flags). Bearer the SaleSwitch app presents to `/api/flags`.
FEATURE_FLAGS_READ_TOKEN=""

# Badge graphic gallery read token (cp-app-settings). Bearer for `/api/badge-graphics`.
BADGE_GRAPHIC_READ_TOKEN=""

# Local directory for uploaded badge graphic assets (cp-app-settings).
BADGE_GRAPHIC_STORAGE_DIR="./data/badge-graphics"
# Max stored AVIF per badge (20 KB target for fast gallery loads).
BADGE_GRAPHIC_MAX_BYTES="20480"

# Local dev: read AVIFs from the sibling Badgy repo when not copied into storage.
# Avoids running the import script on every clone. Leave empty in production.
BADGE_GRAPHIC_FALLBACK_DIR="../badgy/public/images/badge-graphics"

# Production: public URL of this control plane (e.g. https://cp.apoaap.io) so Badgy
# on another host gets absolute image URLs from GET /api/badge-graphics.
BADGE_GRAPHIC_PUBLIC_BASE_URL=""

NODE_ENV="development"
SESSION_TTL_SECONDS="28800"
SUBSCRIPTION_CACHE_TTL_SECONDS="120"
