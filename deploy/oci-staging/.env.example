# Copy to .env on the VM. Never commit .env.
# CONTROL_PLANE_DOMAIN must already resolve to the staging VM; SaleSwitch Caddy
# terminates TLS for this host (see Caddyfile.fragment).

CONTROL_PLANE_DOMAIN=staging.admin.apoaap.shop

# Docker network name of the SaleSwitch staging Compose project (for Caddy reachability).
# Inspect with: docker network ls | grep oci-staging
SALESWITCH_DOCKER_NETWORK=oci-staging_default

POSTGRES_USER=control_plane
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=control_plane_staging

# SaleSwitch read-replica (or fixture/stub DSN). Prefer a read-only role.
SALESWITCH_REPLICA_URL=postgresql://readonly:replace-me@saleswitch-postgres:5432/saleswitch_staging?schema=public

# WorkOS AuthKit (staging tenant). Redirect URI is overridden in Compose to
# https://${CONTROL_PLANE_DOMAIN}/auth/callback — keep WORKOS dashboard in sync.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=replace-with-at-least-32-character-secret

# Must match SaleSwitch staging SHOPIFY_API_SECRET for support-chat token verify.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Optional observability
SENTRY_DSN=

# Integration tokens — must match SaleSwitch staging counterparts when enabled.
FEATURE_FLAGS_READ_TOKEN=
BADGE_GRAPHIC_READ_TOKEN=
SALESWITCH_ADMIN_API_URL=
SALESWITCH_ADMIN_API_TOKEN=
SALESWITCH_INTERNAL_API_URL=
SALESWITCH_INTERNAL_API_SECRET=

# Optional: only used by deploy.sh HTTPS verification when Caddy Basic Auth is on.
# Format: username:password  (leave empty if Basic Auth is disabled)
CONTROL_PLANE_BASIC_AUTH=
